PORT=8080

# Keep API version configurable from one place.
CASHFREE_API_VERSION=2025-01-01

# Sandbox credentials (for testing)
CASHFREE_SANDBOX_CLIENT_ID=your_sandbox_client_id
CASHFREE_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret

# Production credentials (for live payments)
CASHFREE_PROD_CLIENT_ID=your_production_client_id
CASHFREE_PROD_CLIENT_SECRET=your_production_client_secret
